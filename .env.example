# Nano Banana 工具环境变量模板
# 使用方法：
# 1. 复制为 .env
# 2. 填入你自己的密钥或代理地址
# 3. 在 shell 中执行：source .env

# 必填：Gemini API Key
export NANOBANANA_API_KEY="your-gemini-api-key-here"

# 可选：覆盖默认模型
export NANOBANANA_MODEL="gemini-3.1-flash-image-preview"

# 可选：如果你有自建网关或反向代理，只填 base URL 即可
# 例如官方接口可写成：
# export NANOBANANA_API_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
# 代码会自动在后面拼接：
# /models/{model}:generateContent?key={api_key}
export NANOBANANA_API_BASE_URL=""

# 可选：只有在你的代理端点路径不规则时，才填写完整模板
# 变量中必须保留 {model} 和 {api_key} 这两个占位符
# export NANOBANANA_PROXY_ENDPOINT="https://your-proxy.example.com/custom-path/{model}?key={api_key}"
export NANOBANANA_PROXY_ENDPOINT=""

# 可选：系统级 HTTP/HTTPS 代理
export HTTP_PROXY=""
export HTTPS_PROXY=""
export ALL_PROXY=""
export NO_PROXY="127.0.0.1,localhost"
